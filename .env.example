# Qanal configuration — copy to .env and adjust

# Listen address (default: :8080)
QANAL_ADDR=:8080

# Storage directory for transfer data (default: ./data)
QANAL_STORAGE=./data

# Maximum file size in bytes (default: 100 GB)
QANAL_MAX_FILE_SIZE=107374182400

# Maximum chunk size in bytes (default: 500 MB)
QANAL_MAX_CHUNK_SIZE=524288000

# Transfer expiry duration (default: 24h)
QANAL_TRANSFER_TTL=24h
