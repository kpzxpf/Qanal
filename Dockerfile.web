# ── Stage 1: build React frontend ─────────────────────────────────────────────
FROM node:22-alpine AS frontend

WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm ci --prefer-offline

COPY frontend/ ./
RUN npm run build          # outputs to frontend/dist

# ── Stage 2: build Go web server ──────────────────────────────────────────────
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Inject built frontend into cmd/web/dist so //go:embed dist works.
COPY --from=frontend /app/frontend/dist ./cmd/web/dist

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -o /webapp ./cmd/web

# ── Stage 3: minimal runtime image ────────────────────────────────────────────
FROM alpine:3.21

RUN apk add --no-cache ca-certificates wget && \
    adduser -D -H -h /app qanal

WORKDIR /app
COPY --from=builder /webapp /app/webapp

RUN mkdir -p /data && chown qanal:qanal /data
USER qanal

VOLUME /data

ENV QANAL_ADDR=:8080
ENV QANAL_STORAGE=/data
ENV QANAL_TRANSFER_TTL=24h
ENV QANAL_MAX_FILE_SIZE=107374182400
ENV QANAL_MAX_CHUNK_SIZE=536870912

EXPOSE 8080
ENTRYPOINT ["/app/webapp"]
